# ==========================================
# 파이썬 데이터 분석 프로젝트용 .gitignore
# ==========================================

# --- 파이썬 컴파일 및 캐시 파일 ---
__pycache__/
*.py[cod]
*$py.class

# --- 가상환경 (Virtual Environments) ---
.venv/
venv/
ENV/
env/

# --- Jupyter Notebook 관련 ---
.ipynb_checkpoints
*/.ipynb_checkpoints/*
.ipynb_checkpoints/
.ipython/
profile_default/
ipython_config.py

# --- 데이터 디렉토리 및 대용량 데이터 파일 ---
data/
raw_data/
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.pkl
*.pickle
*.h5
*.hdf5
*.npy
*.npz
*.db
*.sqlite3

# project2 대시보드 배포용 가교 데이터셋 예외 허용
!project2/data/ec_mapped_with_api.csv

# --- 환경변수 및 API 키 등 보안 관련 파일 ---
.env
.env.shared
.env.secret
.secrets
credentials.json
*.pem
*.key

# --- IDE 및 에디터 설정 ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# --- OS 임시 파일 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- 숨김 파일 및 폴더 ---
.*
!.gitignore
!.streamlit/
.streamlit/secrets.toml
**/secrets.toml
